/* 全局样式 - F1 暗色主题 */
page {
  background-color: #0f0f0f;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

/* 通用卡片 */
.card {
  background-color: #1a1a1a;
  border-radius: 12rpx;
  margin: 16rpx;
  padding: 24rpx;
}

/* 红色强调色 */
.accent { color: #e10600; }
.accent-bg { background-color: #e10600; }

/* 次要文字 */
.text-muted { color: #888888; font-size: 24rpx; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #2a2a2a;
  margin: 16rpx 0;
}

/* 按钮 */
.btn-primary {
  background-color: #e10600;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-secondary {
  background-color: #2a2a2a;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
}

/* Flex 工具类 */
.row { display: flex; flex-direction: row; align-items: center; }
.col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }

/* 加载态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #888888;
  font-size: 28rpx;
}

/* 车队色块 */
.team-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
}
