<!-- pages/forum-register/forum-register.wxml -->
<view style="min-height:100vh; background:#0f0f0f; padding:60rpx 40rpx;">

  <view style="text-align:center; margin-bottom:60rpx;">
    <text style="font-size:100rpx; display:block; margin-bottom:24rpx;">🏎️</text>
    <text style="font-size:36rpx; font-weight:bold; color:#f0f0f0; display:block; margin-bottom:12rpx;">设置你的论坛昵称🤪</text>
    <text style="font-size:26rpx; color:#888; display:block;">畅享 F1 讨论社区，丫够燥的！</text>
  </view>

  <view style="margin-bottom:16rpx; display:flex; justify-content:space-between;">
    <text style="font-size:26rpx; color:#888;">昵称</text>
    <text style="font-size:22rpx; color:#666;">{{nicknameLen}}/12</text>
  </view>

  <textarea
    style="width:100%; background:#2a2a2a; border-radius:16rpx; padding:32rpx 28rpx; font-size:32rpx; color:#e0e0e0; box-sizing:border-box; min-height:100rpx;"
    placeholder="2-12 个字，随便起"
    placeholder-style="color:#555;"
    maxlength="12"
    bindinput="onNicknameInput"
    value="{{nickname}}"
    auto-height
    focus
  />

  <text style="font-size:22rpx; color:#555; display:block; margin-top:12rpx; text-align:center;">不含特殊符号，设置后可修改</text>

  <view
    style="margin-top:60rpx; background:{{submitting ? '#444' : '#e10600'}}; border-radius:16rpx; padding:36rpx; text-align:center;"
    bindtap="onSubmit"
  >
    <text style="font-size:32rpx; color:#fff; font-weight:bold;">{{submitting ? '注册中...' : '确认并进入论坛'}}</text>
  </view>

</view>
