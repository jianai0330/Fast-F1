/* pages/forum-register/forum-register.wxss */
.container {
  min-height: 100vh; background: #0f0f0f;
  padding: 60rpx 40rpx 40rpx; display: flex;
  flex-direction: column; align-items: center;
}

.hero { text-align: center; margin-bottom: 60rpx; }
.hero-icon  { font-size: 100rpx; display: block; margin-bottom: 24rpx; }
.hero-title { font-size: 36rpx; font-weight: bold; color: #f0f0f0; display: block; margin-bottom: 12rpx; }
.hero-sub   { font-size: 26rpx; color: #666; display: block; }

.field-wrap { width: 100%; margin-bottom: 40rpx; }
.field-header {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 16rpx;
}
.field-label { font-size: 26rpx; color: #888; }
.field-count { font-size: 22rpx; color: #444; }
.count-warn  { color: #e10600; }

.nick-input {
  width: 100%; background: #1a1a1a; border-radius: 16rpx;
  padding: 28rpx; font-size: 32rpx; color: #e0e0e0;
  border: 1rpx solid #2a2a2a; text-align: center;
  letter-spacing: 4rpx; box-sizing: border-box;
}
.ph { color: #444; text-align: center; }

.field-hint { font-size: 22rpx; color: #444; display: block; margin-top: 12rpx; text-align: center; }

.submit-btn {
  width: 100%; background: #e10600; border-radius: 16rpx;
  padding: 36rpx; text-align: center;
  font-size: 32rpx; color: #fff; font-weight: bold;
}
.submit-disabled { background: #444; }
