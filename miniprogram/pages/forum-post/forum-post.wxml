<!-- pages/forum-post/forum-post.wxml -->
<wxs module="fmt" src="./forum-post.wxs"></wxs>

<view class="container">

  <!-- 加载 -->
  <view wx:if="{{loading}}" class="state-center">
    <text class="text-muted">加载中...</text>
  </view>

  <block wx:else>
    <scroll-view scroll-y class="post-scroll">

      <!-- 来源新闻卡片 -->
      <view wx:if="{{post.news_id}}" class="news-source-card" bindtap="onGoNews">
        <view class="news-source-left">
          <text class="news-source-label">来源新闻</text>
          <text class="news-source-title">{{post.news_title}}</text>
          <text class="news-source-from">{{post.news_source}}</text>
        </view>
        <text class="news-source-arrow">→</text>
      </view>

      <!-- 帖子主体 -->
      <view class="post-body" wx:if="{{post}}">
        <view wx:if="{{post.is_seeded}}" class="seeded-badge">
          <text>✨ AI资讯</text>
        </view>
        <text class="post-title">{{post.title}}</text>
        <view class="post-meta">
          <text class="meta-author">{{post.author_nickname}}</text>
          <text class="meta-dot">·</text>
          <text class="meta-time">{{fmt.time(post.created_at)}}</text>
          <text class="meta-section">· {{post.section_name}}</text>
        </view>
        <view class="divider"></view>
        <text class="post-content">{{post.content}}</text>

        <!-- 点赞/点踩 + 删帖 -->
        <view class="action-bar">
          <view class="like-group">
            <view class="like-btn {{myVote === 'like' ? 'voted' : ''}}"
                  bindtap="onLike" data-type="like">
              <text class="like-icon">👍</text>
              <text class="like-count">{{likes}}</text>
            </view>
            <view class="like-btn {{myVote === 'dislike' ? 'voted-down' : ''}}"
                  bindtap="onLike" data-type="dislike">
              <text class="like-icon">👎</text>
              <text class="like-count">{{dislikes}}</text>
            </view>
          </view>
          <view wx:if="{{post.author_openid === openid}}"
                class="delete-btn" bindtap="onDeletePost">
            <text>删除</text>
          </view>
        </view>
      </view>

      <!-- 评论区 -->
      <view class="comment-section">
        <text class="comment-header">💬 共 {{comments.length}} 条评论</text>

        <view wx:if="{{comments.length === 0}}" class="empty-comment">
          <text class="text-muted">暂无评论，来说第一句话吧</text>
        </view>

        <!-- 评论列表（线程化） -->
        <view wx:for="{{comments}}" wx:key="id" class="comment-card {{item.parent_id ? 'comment-reply' : ''}}">
          <view class="comment-header-row">
            <view class="avatar-circle" style="background: {{item.parent_id ? '#555' : '#e10600'}};">
              <text class="avatar-text">{{item.author_nickname.substring(0,1)}}</text>
            </view>
            <view class="comment-info">
              <text class="comment-author">{{item.author_nickname}}</text>
              <text class="comment-time">{{fmt.time(item.created_at)}}</text>
            </view>
          </view>
          <text class="comment-content">{{item.content}}</text>

          <!-- 评论操作栏：点赞 + 回复 -->
          <view class="comment-actions">
            <view class="comment-like-btn {{item.liked ? 'comment-liked' : ''}}"
                  bindtap="onCommentLike" data-id="{{item.id}}">
              <text class="cl-icon">{{item.liked ? '❤️' : '🤍'}}</text>
              <text class="cl-count">{{item.like_count || 0}}</text>
            </view>
            <view class="comment-reply-btn" bindtap="onReply" data-id="{{item.id}}" data-nickname="{{item.author_nickname}}">
              <text>💬 回复</text>
            </view>
          </view>
        </view>

      </view>

      <!-- 底部占位 -->
      <view style="height: 130rpx;"></view>

    </scroll-view>

    <!-- 底部评论输入框 -->
    <view class="input-bar">
      <view wx:if="{{replyTo}}" class="reply-indicator" bindtap="onCancelReply">
        <text class="reply-hint">回复 @{{replyTo.nickname}}</text>
        <text class="reply-cancel">取消</text>
      </view>
      <view class="input-row">
        <input
          class="comment-input"
          placeholder="{{replyTo ? '输入回复内容...' : '说点什么...'}}"
          placeholder-class="input-placeholder"
          value="{{inputVal}}"
          bindinput="onInputChange"
          bindfocus="onInputFocus"
          confirm-type="send"
          bindconfirm="onSubmitComment"
          adjust-position
        />
        <view class="send-btn {{submitting ? 'send-btn-disabled' : ''}}"
              bindtap="onSubmitComment">
          <text>发送</text>
        </view>
      </view>
    </view>
  </block>

</view>
