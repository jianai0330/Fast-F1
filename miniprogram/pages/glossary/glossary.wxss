/* pages/glossary/glossary.wxss */

.container {
  height: 100vh;
  background: #0f0f0f;
  display: flex;
  flex-direction: column;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 24rpx 16rpx;
  background: #0f0f0f;
}

.search-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #1a1a1a;
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #2a2a2a;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #f0f0f0;
  height: 40rpx;
}

.search-clear {
  padding: 4rpx 8rpx;
  font-size: 24rpx;
  color: #555;
}

/* 分类 tab */
.cat-scroll {
  white-space: nowrap;
  flex-shrink: 0;
  padding-bottom: 4rpx;
}

.cat-row {
  display: inline-flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 0 24rpx 16rpx;
}

.cat-tab {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid #2a2a2a;
  flex-shrink: 0;
}

.cat-tab text {
  font-size: 24rpx;
  color: #666;
}

.cat-tab-active text {
  font-weight: bold;
}

/* 状态 */
.state-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.muted {
  font-size: 26rpx;
  color: #444;
}

/* 列表 */
.list-scroll {
  flex: 1;
}

.list-wrap {
  padding: 0 24rpx;
}

.term-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #1a1a1a;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #242424;
  overflow: hidden;
}

.term-bar {
  width: 6rpx;
  align-self: stretch;
  flex-shrink: 0;
}

.term-body {
  flex: 1;
  padding: 24rpx 20rpx;
}

.term-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.term-zh {
  font-size: 30rpx;
  font-weight: bold;
  color: #f0f0f0;
}

.term-cat-tag {
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid;
  font-size: 20rpx;
  flex-shrink: 0;
}

.term-en {
  font-size: 22rpx;
  color: #555;
  display: block;
  margin-bottom: 10rpx;
}

.term-def {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.term-arrow {
  font-size: 36rpx;
  color: #333;
  padding-right: 20rpx;
  flex-shrink: 0;
}
