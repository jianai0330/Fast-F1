.container { padding-bottom: 40rpx; }

/* 车手信息栏 */
.driver-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
  background-color: #1a1a1a;
  border-bottom: 1rpx solid #2a2a2a;
}

.driver-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.driver-info-right {
  flex-direction: row-reverse;
}

.driver-dot {
  width: 8rpx;
  height: 72rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.driver-code {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.driver-team {
  font-size: 22rpx;
  display: block;
  margin-top: 2rpx;
}

.driver-time {
  font-size: 26rpx;
  font-weight: bold;
  display: block;
  margin-top: 4rpx;
  font-variant-numeric: tabular-nums;
}

.gap-badge {
  background-color: #2a2a2a;
  border-radius: 8rpx;
  padding: 10rpx 16rpx;
}

.gap-text {
  font-size: 22rpx;
  color: #aaaaaa;
  text-align: center;
}

/* 图表 Tab */
.chart-tabs {
  display: flex;
  flex-direction: row;
  background-color: #141414;
  border-bottom: 1rpx solid #2a2a2a;
}

.chart-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666666;
}

.chart-tab-active {
  color: #ffffff;
  border-bottom: 3rpx solid #e10600;
  font-weight: bold;
}

/* 图表占位 */
.chart-placeholder {
  margin: 16rpx;
  height: 400rpx;
  background-color: #1a1a1a;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #333333;
}

.chart-placeholder-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #e10600;
  display: block;
  margin-bottom: 12rpx;
}

.chart-placeholder-hint {
  font-size: 24rpx;
  color: #555555;
}

/* 弯角提示 */
.corner-hint {
  padding: 8rpx 24rpx;
  overflow: hidden;
}

.corner-hint text {
  font-size: 20rpx;
  line-height: 1.6;
}

/* 数据丢包提示 */
.note-bar {
  margin: 0 16rpx;
  padding: 16rpx;
  background-color: #1f1a00;
  border-radius: 8rpx;
  border-left: 4rpx solid #f0a500;
}

.note-text {
  font-size: 22rpx;
  color: #f0a500;
  line-height: 1.6;
}
