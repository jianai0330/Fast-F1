.container { padding-bottom: 40rpx; }

/* 车手信息栏 */
.driver-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
  background-color: #1a1a1a;
  border-bottom: 1rpx solid #2a2a2a;
}

.driver-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.driver-info-right {
  flex-direction: row-reverse;
}

.driver-dot {
  width: 8rpx;
  height: 72rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.driver-code {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.driver-team {
  font-size: 22rpx;
  display: block;
  margin-top: 2rpx;
}

.driver-time {
  font-size: 26rpx;
  font-weight: bold;
  display: block;
  margin-top: 4rpx;
  font-variant-numeric: tabular-nums;
}

.gap-badge {
  background-color: #2a2a2a;
  border-radius: 8rpx;
  padding: 10rpx 16rpx;
}

.gap-text {
  font-size: 22rpx;
  color: #aaaaaa;
  text-align: center;
}

/* 图表 Tab */
.chart-tabs {
  display: flex;
  flex-direction: row;
  background-color: #141414;
  border-bottom: 1rpx solid #2a2a2a;
}

.chart-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666666;
}

.chart-tab-active {
  color: #ffffff;
  border-bottom: 3rpx solid #e10600;
  font-weight: bold;
}

/* 图表容器 */
.chart-wrap {
  width: 100%;
  height: 420rpx;
  background-color: #1a1a1a;
}

ec-canvas {
  width: 100%;
  height: 420rpx;
}

/* 弯角提示 */
.corner-hint {
  padding: 8rpx 24rpx;
  overflow: hidden;
}

.corner-hint text {
  font-size: 20rpx;
  line-height: 1.6;
}

/* 数据丢包提示 */
.note-bar {
  margin: 0 16rpx;
  padding: 16rpx;
  background-color: #1f1a00;
  border-radius: 8rpx;
  border-left: 4rpx solid #f0a500;
}

.note-text {
  font-size: 22rpx;
  color: #f0a500;
  line-height: 1.6;
}

/* 悬浮查词按钮 */
.term-fab-area {
  position: fixed;
  right: 0;
  bottom: 0;
  width: 200rpx;
  height: 100vh;
  z-index: 999;
  pointer-events: none;
}
.term-fab {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(74, 158, 255, 0.85);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 158, 255, 0.4);
  pointer-events: auto;
}
.fab-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

/* Sheet 遮罩 */
.term-sheet-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
}

/* Sheet 主体 */
.term-sheet {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 60vh;
  background: #1a1a1a;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  padding: 20rpx 32rpx;
  display: flex;
  flex-direction: column;
}
.term-sheet.show {
  transform: translateY(0);
}

/* Sheet 内部样式 */
.sheet-handle {
  width: 60rpx; height: 6rpx;
  background: #555;
  border-radius: 3rpx;
  margin: 0 auto 24rpx;
}
.sheet-title {
  font-size: 32rpx; color: #f0f0f0;
  font-weight: bold; margin-bottom: 20rpx;
}
.sheet-search input {
  background: #2a2a2a;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  color: #f0f0f0;
  font-size: 28rpx;
}
.sheet-results {
  flex: 1; overflow-y: auto; margin-top: 20rpx;
}
.sheet-result-item {
  padding: 20rpx; border-bottom: 1rpx solid #2a2a2a;
}
.result-name { font-size: 30rpx; color: #f0f0f0; font-weight: bold; }
.result-en { font-size: 24rpx; color: #888; margin-top: 4rpx; }
.result-def { font-size: 26rpx; color: #aaa; margin-top: 8rpx; }
.popular-title { font-size: 26rpx; color: #888; margin: 20rpx 0 12rpx; }
.popular-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #2a2a2a;
  border-radius: 24rpx;
  color: #f0f0f0;
  font-size: 26rpx;
  margin: 8rpx 12rpx 8rpx 0;
}
.btn-full-detail {
  background: #4a9eff;
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
  font-size: 28rpx;
  margin-top: 20rpx;
}
