/* curated-submit 暗色主题 */
.container {
  padding: 24rpx 32rpx 120rpx;
  min-height: 100vh;
  background-color: #111;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #eee;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #888;
}

/* 模式切换 */
.mode-switch {
  display: flex;
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #888;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.mode-tab.active {
  background: #2a2a2a;
  color: #f0f0f0;
  font-weight: bold;
}

/* 手动输入表单 */
.manual-form {
  margin-top: 20rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  background: #1a1a1a;
  border: 1rpx solid #2a2a2a;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #f0f0f0;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-textarea {
  background: #1a1a1a;
  border: 1rpx solid #2a2a2a;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #f0f0f0;
  font-size: 28rpx;
  height: 200rpx;
  width: 100%;
  box-sizing: border-box;
}

.char-count {
  font-size: 22rpx;
  color: #555;
  text-align: right;
  margin-top: 8rpx;
  display: block;
}

.platform-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.platform-chip {
  padding: 12rpx 24rpx;
  background: #2a2a2a;
  border-radius: 24rpx;
  color: #999;
  font-size: 26rpx;
  border: 1rpx solid #333;
  transition: all 0.15s ease;
}

.platform-chip.active {
  background: rgba(74, 158, 255, 0.15);
  color: #4a9eff;
  border-color: #4a9eff;
}

/* URL 输入区 */
.input-section {
  margin-bottom: 32rpx;
}

.url-input {
  width: 100%;
  background-color: #1a1a1a;
  color: #eee;
  font-size: 28rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  min-height: 80rpx;
  box-sizing: border-box;
  border: 1rpx solid #2a2a2a;
}

/* 通用段落 */
.section {
  margin-bottom: 28rpx;
}

.section-title {
  display: block;
  font-size: 26rpx;
  color: #aaa;
  margin-bottom: 16rpx;
}

/* 标签 chip */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  background-color: #2a2a2a;
  color: #ccc;
  font-size: 26rpx;
  transition: all 0.15s ease;
  border: 2rpx solid transparent;
}

.tag-chip.tag-active {
  background-color: #e10600;
  color: #fff;
  border-color: #ff4444;
  font-weight: bold;
  transform: scale(1.05);
}

/* 文本输入 */
.text-input {
  width: 100%;
  background-color: #1a1a1a;
  color: #eee;
  font-size: 28rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
  border: 1rpx solid #2a2a2a;
}

/* 提交按钮 */
.submit-btn {
  width: 100% !important;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #e10600;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  margin-top: 16rpx;
  border: none;
}

.submit-btn[disabled] {
  background-color: #4a2020;
  color: #888;
}

/* 结果预览卡片 */
.result-card {
  margin-top: 32rpx;
  background-color: #1a1a1a;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid #2a2a2a;
}

.result-cover {
  width: 100%;
  height: 280rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.result-title {
  display: block;
  font-size: 30rpx;
  color: #eee;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.result-platform {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.result-success {
  display: block;
  font-size: 28rpx;
  color: #4caf50;
  font-weight: bold;
}
