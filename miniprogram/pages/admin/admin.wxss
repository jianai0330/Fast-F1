/* pages/admin/admin.wxss */

/* ── 基础容器 ── */
.container {
  min-height: 100vh;
  background: #0f0f0f;
  display: flex;
  flex-direction: column;
}

/* ── 锁屏 ── */
.lock-screen {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}
.lock-icon {
  font-size: 120rpx;
  display: block;
}
.lock-tip {
  font-size: 26rpx;
  color: #444;
}

/* ── 管理界面 ── */
.admin-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 顶部栏 */
.admin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}
.admin-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #f0f0f0;
}
.crawl-btn {
  background: #e10600;
  border-radius: 12rpx;
  padding: 14rpx 28rpx;
}
.crawl-btn text {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

/* ── Tab 栏 ── */
.tab-bar {
  display: flex;
  border-bottom: 1rpx solid #222;
  padding: 0 32rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}
.tab-active {
  color: #e10600;
  border-bottom: 4rpx solid #e10600;
  font-weight: bold;
}
.badge {
  background: #e10600;
  color: #fff;
  font-size: 20rpx;
  border-radius: 20rpx;
  padding: 2rpx 10rpx;
  min-width: 36rpx;
  text-align: center;
}

/* ── 状态 ── */
.state-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.text-muted { color: #555; font-size: 28rpx; }

/* ── 滚动区 ── */
.review-scroll {
  flex: 1;
  padding: 24rpx 32rpx;
}
.empty-wrap {
  padding: 80rpx 0;
  text-align: center;
}

/* ── 审核卡片 ── */
.review-card {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}
.review-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}
.review-author {
  font-size: 24rpx;
  color: #e10600;
  font-weight: bold;
}
.review-section {
  font-size: 22rpx;
  color: #555;
}
.review-title {
  display: block;
  font-size: 28rpx;
  color: #e0e0e0;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.review-content {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  max-height: 120rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

/* ── 操作按钮 ── */
.action-row {
  display: flex;
  gap: 20rpx;
}
.btn-approve,
.btn-reject {
  flex: 1;
  border-radius: 12rpx;
  padding: 16rpx 0;
  text-align: center;
}
.btn-approve {
  background: #1a3a1a;
  border: 1rpx solid #2e7d32;
}
.btn-approve text {
  font-size: 26rpx;
  color: #66bb6a;
  font-weight: bold;
}
.btn-reject {
  background: #3a1a1a;
  border: 1rpx solid #7d2e2e;
}
.btn-reject text {
  font-size: 26rpx;
  color: #ef5350;
  font-weight: bold;
}
