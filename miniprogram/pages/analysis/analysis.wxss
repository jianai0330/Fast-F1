.container { padding-bottom: 60rpx; }

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

/* 缓存提示 */
.cache-badge {
  background-color: #0f2a0f;
  padding: 10rpx 24rpx;
  margin: 16rpx 16rpx 0;
  border-radius: 8rpx;
  border-left: 4rpx solid #2ecc40;
}

.cache-badge text {
  font-size: 22rpx;
  color: #2ecc40;
}

/* 报告头 */
.report-header {
  padding: 24rpx 24rpx 16rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  letter-spacing: 4rpx;
}

.report-subtitle {
  display: block;
  margin-top: 6rpx;
}

/* 折叠卡片 */
.section-card {
  margin: 12rpx 16rpx;
  background-color: #1a1a1a;
  border-radius: 12rpx;
  overflow: hidden;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #2a2a2a;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #e10600;
}

.section-arrow {
  font-size: 22rpx;
  color: #555555;
}

.section-content {
  padding: 20rpx 24rpx;
}

.section-text {
  font-size: 26rpx;
  color: #cccccc;
  line-height: 1.8;
  display: block;
  white-space: pre-wrap;
}
