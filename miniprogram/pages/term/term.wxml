<!-- pages/term/term.wxml -->
<view class="container">

  <view wx:if="{{loading}}" class="state-center">
    <text class="text-muted">加载中...</text>
  </view>

  <view wx:elif="{{error}}" class="state-center">
    <text class="error-text">{{error}}</text>
  </view>

  <scroll-view wx:else scroll-y class="scroll">

    <!-- 浏览面包屑 -->
    <view wx:if="{{breadcrumb.length > 0}}" class="breadcrumb-bar">
      <view class="breadcrumb-inner">
        <block wx:for="{{breadcrumb}}" wx:key="slug">
          <text wx:if="{{index > 0}}" class="breadcrumb-sep">></text>
          <text class="breadcrumb-item"
                bindtap="onBreadcrumbTap"
                data-slug="{{item.slug}}">{{item.name}}</text>
        </block>
        <text class="breadcrumb-sep">></text>
        <text class="breadcrumb-item current">{{term.name_zh}}</text>
      </view>
    </view>

    <!-- 头部 -->
    <view class="header" style="border-color: {{term.color}};">
      <view class="header-top">
        <view class="names">
          <text class="name-zh">{{term.name_zh}}</text>
          <text class="name-en">{{term.name_en}}</text>
        </view>
        <view class="level-badge" style="color: {{term.color}}; border-color: {{term.color}}; background: {{term.color}}18;">
          <text>{{term.level_label}}</text>
        </view>
      </view>
      <view class="meta-row">
        <view class="cat-tag" style="color: {{term.color}}; background: {{term.color}}18;">
          <text>{{term.category_label}}</text>
        </view>
        <text wx:if="{{term.spec_year}}" class="spec-year">{{term.spec_year}} 规则</text>
      </view>
    </view>

    <!-- 别名 -->
    <view wx:if="{{term.aliases_list.length > 0}}" class="section">
      <text class="section-label">别名 / 关键词</text>
      <view class="aliases-row">
        <view wx:for="{{term.aliases_list}}" wx:key="*this" class="alias-tag">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 一句话解释 -->
    <view class="section">
      <text class="section-label">简介</text>
      <text class="short-def">{{term.short_def}}</text>
    </view>

    <!-- 为什么重要 -->
    <view wx:if="{{term.why_important}}" class="section">
      <text class="section-label">💡 为什么重要</text>
      <view class="why-box" style="border-left: 6rpx solid {{term.color}}33;">
        <text class="why-text">{{term.why_important}}</text>
      </view>
    </view>

    <!-- 详细解释 -->
    <view wx:if="{{term.full_def}}" class="section">
      <text class="section-label">详细解释</text>
      <text class="full-def">{{term.full_def}}</text>
    </view>

    <!-- 经典案例 -->
    <view wx:if="{{term.example}}" class="section">
      <text class="section-label">📌 经典案例</text>
      <view class="example-box">
        <text class="example-text">{{term.example}}</text>
      </view>
    </view>

    <!-- 数据参考 -->
    <view wx:if="{{term.data_ref}}" class="section">
      <text class="section-label">📊 数据参考</text>
      <view class="data-box">
        <text class="data-text">{{term.data_ref}}</text>
      </view>
    </view>

    <!-- 术语关系辐射图 -->
    <view wx:if="{{radialNodes.length > 0}}" class="section">
      <text class="section-label">相关术语</text>
      <view class="radial-container">
        <!-- 中心圆 -->
        <view class="radial-center" style="background: {{term.color}}33;">
          <text class="radial-center-text">{{term.name_zh}}</text>
        </view>
        <!-- 虚线圆环 -->
        <view class="radial-dashed-ring"></view>
        <!-- 外围节点 -->
        <view wx:for="{{radialNodes}}" wx:key="slug"
              class="radial-node"
              style="transform: translate({{item.x}}rpx, {{item.y}}rpx);"
              bindtap="onGoRelated"
              data-slug="{{item.slug}}">
          <view class="radial-node-inner">
            <text class="radial-node-text">{{item.name_zh}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 继续深入了解按钮 -->
    <view class="deep-btn" bindtap="onDeepDive">
      <text class="deep-btn-text">继续深入了解 ✨</text>
    </view>

    <view style="height: 60rpx;"></view>

  </scroll-view>

  <!-- 假功能弹窗 -->
  <view wx:if="{{deepVisible}}" class="deep-mask" bindtap="onCloseDeep">
    <view class="deep-card" catchtap="noop">
      <view class="deep-handle"></view>
      <text class="deep-title">🤖 AI 深度解析</text>
      <text class="deep-body">别花我 token 自己去问！</text>
      <view class="deep-copy-btn" bindtap="onCopyTerm">
        <text class="deep-copy-text">点击复制</text>
      </view>
    </view>
  </view>

</view>
