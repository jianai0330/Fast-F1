<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">F1 {{year}}</text>
    <text class="subtitle">chua的赛历</text>
  </view>

  <!-- 下一站倒计时 -->
  <view wx:if="{{nextRace}}" class="countdown-card">
    <view class="countdown-left">
      <text class="countdown-name">{{nextRace.shortName}}</text>
      <text class="countdown-bj">北京时间 {{nextRace.race_time_bj}}</text>
    </view>
    <view class="countdown-right">
      <text class="countdown-label-text">距正赛</text>
      <text class="countdown-timer">{{countdown}}</text>
    </view>
  </view>

  <view wx:if="{{seasonSummary}}" class="cockpit-strip">
    <view class="cockpit-stat">
      <text class="cockpit-label">已完成</text>
      <text class="cockpit-value">{{seasonSummary.completed}}</text>
    </view>
    <view class="cockpit-stat">
      <text class="cockpit-label">待进行</text>
      <text class="cockpit-value">{{seasonSummary.upcoming}}</text>
    </view>
    <view class="cockpit-stat">
      <text class="cockpit-label">总分站</text>
      <text class="cockpit-value">{{seasonSummary.total}}</text>
    </view>
  </view>

  <view wx:if="{{latestRaceEntry}}" class="latest-data-card" bindtap="onLatestRaceTap">
    <view class="latest-data-head">
      <text class="latest-data-kicker">🏁 最新赛站数据</text>
      <text class="latest-data-arrow">查看详情 ›</text>
    </view>
    <text class="latest-data-name">R{{latestRaceEntry.round}} · {{latestRaceEntry.name}}</text>
    <text class="latest-data-meta">{{latestRaceEntry.location}}</text>
  </view>

  <view class="quick-actions quick-actions-compact">
    <view
      wx:for="{{quickActions}}"
      wx:key="key"
      class="quick-action-card"
      bindtap="onQuickActionTap"
      data-url="{{item.url}}"
      data-type="{{item.type}}"
    >
      <text class="quick-action-label">{{item.label}}</text>
      <text class="quick-action-hint">{{item.hint}}</text>
    </view>
  </view>

  <!-- 可滚动内容区 -->
  <scroll-view class="content-scroll" scroll-y>
    <!-- 加载中 - 骨架屏 -->
    <view wx:if="{{loading}}" class="skeleton-wrap">
      <view class="sk-event-item" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
        <view class="sk-round"></view>
        <view class="sk-event-body">
          <view class="sk-line sk-long"></view>
          <view class="sk-line sk-mid"></view>
        </view>
      </view>
    </view>

    <!-- 错误 -->
    <view wx:elif="{{error}}" class="loading-wrap">
      <text class="text-muted">{{error}}</text>
    </view>

    <!-- 赛历列表 -->
    <view wx:else class="event-list">
      <view
        wx:for="{{events}}"
        wx:key="round"
        class="event-item {{item.status === 'completed' ? 'event-completed' : ''}} {{item.status === 'next' ? 'event-next' : ''}}"
        bindtap="onEventTap"
        data-event="{{item}}"
      >
        <view class="round-badge">R{{item.round}}
          <view wx:if="{{item.status === 'next'}}" class="next-badge">NEXT</view>
        </view>
        <view class="event-info flex-1">
          <view class="event-top-row">
            <text class="event-name">{{item.name}}</text>
          </view>
          <view class="event-bottom-row">
            <text class="event-meta">{{item.location}} · {{item.date}}</text>
            <view wx:if="{{item.circuitSvg}}" class="circuit-track-slot">
              <image
                class="circuit-track-image"
                src="{{item.circuitSvg}}"
                mode="aspectFit"
              ></image>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
