.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  overflow: hidden;
}

.header {
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #2a2a2a;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #e10600;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #888888;
  margin-top: 4rpx;
  display: block;
}

/* ── 倒计时卡片 ── */
.countdown-card {
  margin: 20rpx 16rpx 4rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #1e0a0a 0%, #2a0d0d 60%, #1a1a1a 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(225, 6, 0, 0.35);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.countdown-left {
  flex: 1;
}

.countdown-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.countdown-bj {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-top: 6rpx;
}

.countdown-right {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
}

.countdown-label-text {
  font-size: 20rpx;
  color: #e10600;
  display: block;
  margin-bottom: 4rpx;
}

.countdown-timer {
  font-size: 36rpx;
  font-weight: bold;
  color: #e10600;
  letter-spacing: 2rpx;
  font-variant-numeric: tabular-nums;
  display: block;
}

.cockpit-strip {
  margin: 8rpx 16rpx 0;
  padding: 18rpx 20rpx;
  display: flex;
  gap: 12rpx;
  background: linear-gradient(180deg, #151515 0%, #101010 100%);
  border-radius: 14rpx;
  border: 1rpx solid #262626;
}

.cockpit-stat {
  flex: 1;
  min-width: 0;
}

.cockpit-label {
  display: block;
  font-size: 20rpx;
  color: #8a8a8a;
}

.cockpit-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.latest-race-card {
  margin: 12rpx 16rpx 4rpx;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
  background:
    radial-gradient(circle at top right, rgba(225, 6, 0, 0.18), transparent 35%),
    linear-gradient(145deg, #171717 0%, #111111 100%);
  border: 1rpx solid #262626;
}

.latest-race-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.latest-race-kicker {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: #8a8a8a;
}

.latest-race-status {
  font-size: 20rpx;
  color: #e10600;
}

.latest-race-name {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.latest-race-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a8a8a;
}

.quick-actions {
  margin: 12rpx 16rpx 8rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.quick-action-card {
  padding: 22rpx 22rpx 20rpx;
  border-radius: 14rpx;
  background:
    linear-gradient(160deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%),
    #121212;
  border: 1rpx solid #232323;
}

.quick-action-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f3f3f3;
}

.quick-action-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.45;
  color: #858585;
}

/* ── 赛历列表 ── */
.event-list {
  padding: 16rpx;
}

.event-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #1a1a1a;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.event-item:active {
  transform: scale(0.97);
  opacity: 0.88;
}

.round-badge {
  width: 72rpx;
  height: 72rpx;
  background-color: #e10600;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 24rpx;
  flex-shrink: 0;
  text-align: center;
  line-height: 72rpx;
}

.event-info {
  display: flex;
  flex-direction: column;
}

.event-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

.event-meta {
  font-size: 24rpx;
  color: #888888;
  margin-top: 6rpx;
  display: block;
}

.circuit-canvas {
  width: 100rpx;
  height: 70rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
