.container {
  padding-bottom: 40rpx;
}

.header {
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #2a2a2a;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #e10600;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #888888;
  margin-top: 4rpx;
  display: block;
}

.event-list {
  padding: 16rpx;
}

.event-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #1a1a1a;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.round-badge {
  width: 72rpx;
  height: 72rpx;
  background-color: #e10600;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 24rpx;
  flex-shrink: 0;
  text-align: center;
  line-height: 72rpx;
}

.event-info {
  display: flex;
  flex-direction: column;
}

.event-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

.event-meta {
  font-size: 24rpx;
  color: #888888;
  margin-top: 6rpx;
  display: block;
}

.arrow {
  font-size: 40rpx;
  color: #444444;
  margin-left: 16rpx;
}
