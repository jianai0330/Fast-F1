.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.container.fade-in {
  opacity: 1;
}

.content-scroll {
  flex: 1;
  overflow: hidden;
}

.header {
  padding: 28rpx 24rpx 16rpx;
  border-bottom: 1rpx solid #2a2a2a;
}

.title {
  font-size: 42rpx;
  font-weight: bold;
  color: #e10600;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #888888;
  margin-top: 4rpx;
  display: block;
}

/* ── 倒计时卡片 ── */
.countdown-card {
  margin: 12rpx 12rpx 4rpx;
  padding: 18rpx 20rpx;
  background: linear-gradient(135deg, #1e0a0a 0%, #2a0d0d 60%, #1a1a1a 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(225, 6, 0, 0.35);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.countdown-left {
  flex: 1;
  min-width: 0;
}

.countdown-name {
  font-size: 22rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.countdown-bj {
  font-size: 18rpx;
  color: #888;
  display: block;
  margin-top: 4rpx;
}

.countdown-right {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.countdown-label-text {
  font-size: 17rpx;
  color: #e10600;
  display: block;
  margin-bottom: 2rpx;
}

.countdown-timer {
  font-size: 27rpx;
  font-weight: bold;
  color: #e10600;
  letter-spacing: 1rpx;
  font-variant-numeric: tabular-nums;
  display: block;
  white-space: nowrap;
}

.cockpit-strip {
  margin: 8rpx 12rpx 0;
  padding: 12rpx 14rpx;
  display: flex;
  gap: 8rpx;
  background: linear-gradient(180deg, #151515 0%, #101010 100%);
  border-radius: 14rpx;
  border: 1rpx solid #262626;
}

.cockpit-stat {
  flex: 1;
  min-width: 0;
}

.cockpit-label {
  display: block;
  font-size: 17rpx;
  color: #8a8a8a;
}

.cockpit-value {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.latest-data-card {
  margin: 8rpx 12rpx 4rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background:
    radial-gradient(circle at top right, rgba(225, 6, 0, 0.18), transparent 35%),
    linear-gradient(145deg, #171717 0%, #111111 100%);
  border: 1rpx solid #262626;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.latest-data-card:active {
  transform: scale(0.97);
  opacity: 0.88;
}

.latest-data-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.latest-data-kicker {
  font-size: 17rpx;
  letter-spacing: 2rpx;
  color: #8a8a8a;
}

.latest-data-arrow {
  font-size: 17rpx;
  color: #e10600;
  flex-shrink: 0;
}

.latest-data-name {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.25;
}

.latest-data-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #8a8a8a;
}

.quick-actions {
  margin: 8rpx 12rpx 6rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
}

.quick-action-card {
  padding: 14rpx 14rpx 12rpx;
  border-radius: 14rpx;
  background:
    linear-gradient(160deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%),
    #121212;
  border: 1rpx solid #232323;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.quick-action-card:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.quick-action-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #f3f3f3;
}

.quick-action-hint {
  display: block;
  margin-top: 4rpx;
  font-size: 17rpx;
  line-height: 1.35;
  color: #858585;
}

/* ── 赛历列表 ── */
.event-list {
  padding: 8rpx 12rpx 20rpx;
}

.event-completed {
  opacity: 0.55;
}

.event-completed .event-name {
  color: #888;
}

.event-next .round-badge {
  background: linear-gradient(135deg, #ff3b30, #e10600);
  position: relative;
  overflow: visible;
}

.next-badge {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  font-size: 14rpx;
  font-weight: bold;
  color: #fff;
  background: #e10600;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 2rpx 8rpx rgba(225, 6, 0, 0.5);
}

.event-next .event-name {
  color: #ffffff;
}

.event-next .event-meta {
  color: #e10600;
}

.event-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  background-color: #1a1a1a;
  border-radius: 12rpx;
  padding: 20rpx 18rpx 18rpx;
  margin-bottom: 8rpx;
  transition: transform 0.12s ease, opacity 0.12s ease;
  gap: 16rpx;
}

.event-item:active {
  transform: scale(0.97);
  opacity: 0.88;
}

.round-badge {
  width: 60rpx;
  height: 60rpx;
  background-color: #e10600;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  color: #ffffff;
  flex-shrink: 0;
  text-align: center;
  line-height: 60rpx;
}

.event-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.event-top-row {
  display: flex;
  align-items: flex-start;
  min-width: 0;
}

.event-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 10rpx;
}

.event-name {
  font-size: 33rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  line-height: 1.25;
}

.event-meta {
  font-size: 27rpx;
  color: #9d9d9d;
  display: block;
  flex: 1;
  min-width: 0;
}

.circuit-track-slot {
  width: 132rpx;
  min-width: 132rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.circuit-track-image {
  width: 118rpx;
  height: 56rpx;
  opacity: 1;
}

/* ── 骨架屏 ── */
.skeleton-wrap {
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sk-event-item {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 20rpx 18rpx;
  background: #1a1a1a;
  border-radius: 12rpx;
  align-items: flex-start;
}

.sk-round {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(90deg, #2a2a2a 25%, #333 50%, #2a2a2a 75%);
  background-size: 400% 100%;
  border-radius: 8rpx;
  animation: shimmer 1.4s ease infinite;
  flex-shrink: 0;
}

.sk-event-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sk-line {
  height: 24rpx;
  background: linear-gradient(90deg, #2a2a2a 25%, #333 50%, #2a2a2a 75%);
  background-size: 400% 100%;
  border-radius: 6rpx;
  animation: shimmer 1.4s ease infinite;
}

.sk-long  { width: 70%; }
.sk-mid   { width: 50%; }

@keyframes shimmer {
  0%   { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}
