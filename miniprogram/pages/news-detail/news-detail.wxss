/* pages/news-detail/news-detail.wxss */

.container {
  min-height: 100vh;
  background-color: #0f0f0f;
}

.detail-scroll {
  height: 100vh;
}

/* 状态 */
.state-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.error-text { color: #888; font-size: 28rpx; }
.text-muted { color: #555; font-size: 26rpx; }

/* 标题区 */
.title-section {
  padding: 32rpx 32rpx 24rpx;
  background: #1a1a1a;
  border-bottom: 1rpx solid #2a2a2a;
}

.meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.source-tag {
  font-size: 22rpx;
  color: #e10600;
  background: rgba(225,6,0,0.12);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.time-text {
  font-size: 22rpx;
  color: #555;
}

.news-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #f0f0f0;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}

.origin-btn {
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  color: #4a9eff;
  padding: 8rpx 0;
}

/* 摘要卡片 */
.section-card {
  margin: 24rpx 24rpx 0;
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 28rpx;
  border-left: 4rpx solid #333;
}

.section-label {
  font-size: 22rpx;
  color: #555;
  display: block;
  margin-bottom: 14rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
  display: block;
}

/* AI 解读区 */
.ai-section {
  margin: 24rpx 24rpx 0;
}

/* 分析步骤流程 */
.analysis-pipeline {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 20rpx;
  margin: 16rpx 0 20rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 16rpx;
}
.pipeline-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.35;
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.pipeline-step.active {
  opacity: 1;
  transform: scale(1.05);
}
.step-icon { font-size: 36rpx; }
.step-label { font-size: 20rpx; color: #aaa; margin-top: 8rpx; }
.pipeline-step.active .step-label { color: #f5a623; }
.pipeline-connector {
  width: 40rpx;
  height: 2rpx;
  background: #444;
  margin: 0 6rpx;
}

/* 方法论入口按钮 */
.methodology-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  margin: 16rpx 0 20rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 12rpx;
}
.methodology-btn-text { font-size: 26rpx; color: #ccc; }
.methodology-arrow { font-size: 22rpx; color: #888; }

/* 方法论面板 */
.methodology-panel {
  padding: 24rpx;
  margin: 0 0 20rpx;
  background: rgba(0,0,0,0.3);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
}
.method-header { margin-bottom: 24rpx; }
.method-title { font-size: 28rpx; color: #fff; font-weight: bold; display: block; }
.method-subtitle { font-size: 22rpx; color: #888; margin-top: 8rpx; display: block; }

/* 方法论section */
.method-section { margin-bottom: 28rpx; }
.method-section-label { font-size: 24rpx; color: #aaa; margin-bottom: 16rpx; display: block; }

/* 方法论item */
.method-item {
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 10rpx;
  border-left: 4rpx solid #444;
}
.method-item.active { border-left-color: #f5a623; }
.item-header { display: flex; justify-content: space-between; align-items: center; }
.item-name { font-size: 26rpx; color: #ddd; font-weight: 500; }
.item-tag {
  font-size: 18rpx; padding: 4rpx 10rpx; border-radius: 6rpx;
  background: rgba(245,166,35,0.2); color: #f5a623;
}
.item-tag.tag-race { background: rgba(46,204,113,0.2); color: #2ecc71; }
.item-tag.tag-news { background: rgba(155,89,182,0.2); color: #9b59b6; }
.item-desc { font-size: 22rpx; color: #888; margin-top: 8rpx; line-height: 1.5; display: block; }

/* 知识库网格 */
.knowledge-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.knowledge-card {
  width: calc(50% - 6rpx);
  padding: 16rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
}
.card-icon { font-size: 32rpx; margin-bottom: 8rpx; }
.card-name { font-size: 24rpx; color: #ddd; margin-bottom: 4rpx; }
.card-detail { font-size: 20rpx; color: #777; line-height: 1.4; }

/* 数据管线 */
.pipeline-detail { padding-left: 16rpx; }
.pipe-step {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  position: relative;
}
.pipe-step::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 44rpx;
  bottom: -20rpx;
  width: 2rpx;
  background: #333;
}
.pipe-step:last-child::before { display: none; }
.pipe-num {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(245,166,35,0.2);
  color: #f5a623;
  font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.pipe-content { flex: 1; }
.pipe-name { font-size: 24rpx; color: #ddd; display: block; }
.pipe-desc { font-size: 20rpx; color: #777; margin-top: 4rpx; display: block; }

/* 置信度标签 */
.confidence-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}
.confidence-high { background: rgba(46, 204, 113, 0.2); color: #2ecc71; }
.confidence-medium { background: rgba(241, 196, 15, 0.2); color: #f1c40f; }
.confidence-low { background: rgba(231, 76, 60, 0.2); color: #e74c3c; }

.ai-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.ai-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #f5a623;
}

.ai-sub {
  font-size: 22rpx;
  color: #555;
}

/* AI 三段卡片 */
.ai-card {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #242424;
}

.ai-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.ai-emoji {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.ai-card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ddd;
}

.ai-card-body {
  font-size: 26rpx;
  color: #aaa;
  line-height: 1.8;
  display: block;
}

/* 骨架屏 */
.skeleton-card {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.sk-line {
  height: 22rpx;
  background: #252525;
  border-radius: 6rpx;
  margin-bottom: 16rpx;
}

.sk-short { width: 35%; }
.sk-long  { width: 92%; }
.sk-mid   { width: 68%; }

/* 等待提示 */
.ai-pending {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 40rpx 28rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.ai-trigger-btn {
  background: #e10600;
  border-radius: 12rpx;
  padding: 20rpx 48rpx;
  transition: transform 0.1s ease, opacity 0.1s ease;
}
.ai-trigger-btn:active { transform: scale(0.94); opacity: 0.85; }
.ai-trigger-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}
.ai-trigger-disabled {
  background: #555;
  opacity: 0.7;
}
.ai-trigger-tip {
  font-size: 22rpx;
  color: #555;
}

.reanalyze-btn {
  margin-top: 8rpx;
  padding: 18rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #555;
  transition: opacity 0.12s ease;
}
.reanalyze-btn:active { opacity: 0.5; }
.reanalyze-btn-disabled { opacity: 0.4; pointer-events: none; }
.quote-row {
  display: flex; flex-direction: row;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.quote-btn {
  display: flex; flex-direction: row; align-items: center;
  gap: 6rpx; padding: 8rpx 16rpx;
  background: #222; border-radius: 20rpx;
}

.quote-icon { font-size: 22rpx; }
.quote-text { font-size: 22rpx; color: #666; }

/* 讨论区 */
.discuss-section {
  margin: 24rpx 24rpx 0;
}

.discuss-header {
  display: flex; flex-direction: row; align-items: center;
  gap: 12rpx; margin-bottom: 16rpx;
}

.discuss-title {
  font-size: 30rpx; font-weight: bold; color: #ddd;
}

.discuss-count-tag {
  background: rgba(225,6,0,0.12); border-radius: 20rpx;
  padding: 4rpx 14rpx; font-size: 22rpx; color: #e10600;
}

.related-post-card {
  background: #1a1a1a; border-radius: 14rpx;
  padding: 24rpx 28rpx; margin-bottom: 12rpx;
  border: 1rpx solid #242424;
  transition: transform 0.12s ease, opacity 0.12s ease;
}
.related-post-card:active { transform: scale(0.97); opacity: 0.88; }

.related-post-title {
  font-size: 26rpx; color: #ccc; display: block;
  margin-bottom: 10rpx; line-height: 1.5;
}

.related-post-meta {
  display: flex; flex-direction: row; align-items: center;
  font-size: 22rpx; color: #555; gap: 6rpx;
}
.rp-author { color: #666; }
.rp-dot { color: #444; }
.rp-stat { color: #555; }

.view-all-btn {
  padding: 20rpx 0; text-align: center;
  font-size: 24rpx; color: #4a9eff;
}

.no-discuss {
  padding: 32rpx 0; text-align: center;
}

/* 底部按钮 */
.bottom-btn {
  margin: 20rpx 0 0;
  background: #e10600;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

/* ── 车队标签 ────────────────────────────────── */
.team-tag {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  border: 1rpx solid;
  flex-shrink: 0;
}

.team-tag:active { opacity: 0.7; }

.team-tag-name {
  font-size: 24rpx;
  font-weight: bold;
}

/* ── 术语标签栏 ─────────────────────────────── */
.term-tags-section {
  padding: 20rpx 24rpx 0;
}

.term-tags-scroll {
  white-space: nowrap;
}

.term-tags-row {
  display: inline-flex;
  flex-direction: row;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.term-tag {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 30rpx;
  border: 1rpx solid;
  flex-shrink: 0;
}

.term-tag-name {
  font-size: 24rpx;
  font-weight: bold;
}

.term-tag-level {
  font-size: 20rpx;
  opacity: 0.7;
}

/* ── 术语弹出卡片 ────────────────────────────── */
.term-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.term-card {
  background: #1a1a1a;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 32rpx 60rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.term-card-handle {
  width: 60rpx;
  height: 6rpx;
  background: #333;
  border-radius: 3rpx;
  margin: 0 auto 24rpx;
}

.term-card-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.term-card-names {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.term-name-zh {
  font-size: 36rpx;
  font-weight: bold;
  color: #f0f0f0;
}

.term-name-en {
  font-size: 22rpx;
  color: #666;
}

.term-level-badge {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  border: 1rpx solid;
  font-size: 22rpx;
  flex-shrink: 0;
}

.term-category-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.term-category-tag {
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.term-spec-year {
  font-size: 22rpx;
  color: #555;
}

.term-short-def {
  font-size: 28rpx;
  color: #ccc;
  line-height: 1.7;
  display: block;
  margin-bottom: 20rpx;
}

.term-full-def {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
  display: block;
  margin-bottom: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #242424;
}

.term-example-box {
  background: #111;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.term-example-label {
  font-size: 22rpx;
  color: #555;
  display: block;
  margin-bottom: 10rpx;
}

.term-example-text {
  font-size: 24rpx;
  color: #888;
  line-height: 1.7;
  display: block;
}

.term-card-footer {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 8rpx;
}

.term-btn-detail {
  flex: 1;
  background: #e10600;
  border-radius: 12rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

.term-btn-forum {
  flex: 1;
  background: #222;
  border-radius: 12rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #aaa;
}
