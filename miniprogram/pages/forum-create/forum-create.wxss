/* pages/forum-create/forum-create.wxss */
.container { min-height: 100vh; background: #0f0f0f; padding: 24rpx; }

.section-tag-row {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 32rpx; padding: 24rpx;
  background: #1a1a1a; border-radius: 16rpx;
}
.section-label { font-size: 26rpx; color: #666; }
.section-tag {
  background: rgba(225,6,0,0.12); border-radius: 20rpx;
  padding: 6rpx 20rpx; font-size: 26rpx; color: #e10600;
}

.field-wrap { margin-bottom: 24rpx; }
.field-header {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 12rpx;
}
.field-label { font-size: 26rpx; color: #888; }
.field-count  { font-size: 22rpx; color: #444; }
.count-warn   { color: #e10600; }

.title-input {
  width: 100%; background: #1a1a1a; border-radius: 16rpx;
  padding: 24rpx 28rpx; font-size: 28rpx; color: #e0e0e0;
  border: 1rpx solid #2a2a2a; box-sizing: border-box;
}

.content-input {
  width: 100%; background: #1a1a1a; border-radius: 16rpx;
  padding: 24rpx 28rpx; font-size: 26rpx; color: #ccc;
  border: 1rpx solid #2a2a2a; min-height: 300rpx;
  line-height: 1.8; box-sizing: border-box;
}

.ph { color: #444; }

.tips { margin-bottom: 40rpx; }
.tips-text { font-size: 22rpx; color: #555; }

.submit-btn {
  background: #e10600; border-radius: 16rpx;
  padding: 32rpx; text-align: center;
  font-size: 30rpx; color: #fff; font-weight: bold;
}
.submit-disabled { background: #444; }
