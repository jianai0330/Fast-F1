.tab-bar {
  display: flex;
  flex-direction: row;
  background-color: #1a1a1a;
  border-bottom: 1rpx solid #2a2a2a;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #888888;
}

.tab-active {
  color: #e10600;
  border-bottom: 4rpx solid #e10600;
  font-weight: bold;
}

/* 排位赛表格 */
.quali-header, .quali-row {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.quali-row {
  border-bottom: 1rpx solid #1e1e1e;
}

.col-pos { width: 50rpx; font-size: 26rpx; }
.col-driver { flex: 1; display: flex; flex-direction: column; }
.col-time { width: 150rpx; text-align: right; font-size: 24rpx; color: #cccccc; font-variant-numeric: tabular-nums; }

.driver-code { font-size: 28rpx; font-weight: bold; color: #ffffff; }
.team-name { font-size: 22rpx; color: #888888; margin-top: 2rpx; }

/* 数据对比面板 */
.telemetry-panel { padding: 16rpx; }

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 24rpx;
}

.input-row { align-items: flex-end; gap: 16rpx; }

.input-wrap { display: flex; flex-direction: column; }

.input-label { margin-bottom: 8rpx; }

.driver-input {
  background-color: #2a2a2a;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  text-align: center;
  letter-spacing: 4rpx;
}

.vs-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #444444;
  padding-bottom: 16rpx;
}
